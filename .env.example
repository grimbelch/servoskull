# Copy this file to .env and fill in your values.

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper STT) — https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ElevenLabs (optional cloud TTS) — https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=...

# Picovoice Porcupine (wake word, Pi only) — https://console.picovoice.ai
PORCUPINE_ACCESS_KEY=...
WAKE_WORD=omega seven

# GPIO pins for red eye LEDs (BCM numbering, Pi only)
# GPIO 17 is reserved by the ReSpeaker 2-Mic HAT — use 22/27
LED_PIN_LEFT=22
LED_PIN_RIGHT=27

# Audio device index (-1 = system default)
MIC_DEVICE_INDEX=-1

# Claude model
CLAUDE_MODEL=claude-haiku-4-5-20251001

# TTS backend: "piper" (local, free) or "elevenlabs" (cloud, requires quota)
TTS_BACKEND=piper
PIPER_MODEL_PATH=models/en_GB-alan-medium.onnx

# Spotify (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Google Home cast target (optional)
GOOGLE_HOME_DEVICE=
