# Omega-7 Servo Skull — environment configuration
#
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
#
# `.env` is gitignored and must never be committed. Only ANTHROPIC_API_KEY and
# OPENAI_API_KEY are needed for the basic voice loop (brain + speech-to-text);
# everything else has a sensible default or is for optional features/hardware.
#
# ── Configuration model ───────────────────────────────────────────────────────
# Every user-facing setting below resolves in this order (see skull/config.py):
#     1. settings.json in the user-data dir  (written by the setup wizard)
#     2. this .env / the environment          (developer convenience)
#     3. built-in default
# So on a consumer unit the wizard owns settings.json and .env can be absent.
# Personalization (owner's name, location, family, etc.) lives separately in
# owner.json — see owner.example.json for the shape.
#
# OMEGA7_DATA_DIR: writable directory for all runtime/user data (settings.json,
# owner.json, memory, mood, history, etc.). Defaults to the repo root, which is
# correct for dev and the current Pi layout. On the appliance image, point this
# at a writable path such as /var/lib/omega7 or ~/.config/omega7.
#OMEGA7_DATA_DIR=/var/lib/omega7

# ── Required: core LLM + speech-to-text ──────────────────────────────────────────
# Brain (Claude). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here
# Whisper speech-to-text. Get one at https://platform.openai.com/
OPENAI_API_KEY=your-openai-key-here
# Claude model used for the brain, idle utterances, memory extraction, and vision.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Text-to-speech ──────────────────────────────────────────────────────────────
# "piper" = local, free, offline. "elevenlabs" = cloud voice (quota-limited).
TTS_BACKEND=piper
# Local Piper voice model (downloaded separately; see PI_SETUP_GUIDE.md).
PIPER_MODEL_PATH=models/servoskull.onnx
# ElevenLabs — only needed if TTS_BACKEND=elevenlabs or you use the canned phrases.
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id-here
# Set to true for ONE run to wipe and regenerate the cached canned-phrase audio
# after changing the ElevenLabs voice. Set back to false afterward.
RESET_VOICE_CACHE=false

# ── Wake word (openWakeWord) ─────────────────────────────────────────────────────
# A built-in model name (e.g. "hey_jarvis") or a path to a custom .onnx model.
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# ── Audio devices ────────────────────────────────────────────────────────────────
# Mic: numeric sounddevice index, "-1" for system default, or a name substring
# (e.g. "USB") which survives device re-enumeration. Run `python _miccheck.py` to find it.
MIC_DEVICE_INDEX=-1
# Output device index ("-1" = system default).
AUDIO_OUTPUT_DEVICE=-1
# Pinned device for Omega-7's own voice/SFX (stays on the local speaker even when a
# Bluetooth speaker is the system default). Defaults to AUDIO_OUTPUT_DEVICE if unset.
VOICE_OUTPUT_DEVICE=-1

# ── Weather (get_weather tool) ───────────────────────────────────────────────────
# Your latitude/longitude (decimal degrees). Open-Meteo, no API key required.
# Left at 0.0/0.0 the weather tool reports "not configured".
WEATHER_LAT=0.0
WEATHER_LON=0.0

# ── Spotify (optional music control; Premium required) ───────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id-here
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret-here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Spotify Connect device name for local playback (e.g. Raspotify on the Pi).
SPOTIFY_DEVICE_NAME=Omega-7

# ── Google Home / Chromecast audio (optional) ────────────────────────────────────
# Friendly name of the cast device; leave blank to disable casting.
GOOGLE_HOME_DEVICE=
# Opt-in on macOS, opt-out on Linux/Pi. Requires the pychromecast package.
CAST_ENABLED=false

# ── Camera / motion-triggered vision (optional) ──────────────────────────────────
CAMERA_ENABLED=false
CAMERA_DEVICE_INDEX=0
# ~8% of a 640x480 frame must change to count as motion (raise to desensitize).
CAMERA_MOTION_THRESHOLD=25000
# Min seconds between vision calls triggered by motion.
CAMERA_COOLDOWN=120
# Hard ceiling on vision calls per rolling hour (API-budget backstop).
CAMERA_MAX_PER_HOUR=15
# Mean brightness (0-255) below which a frame is treated as blank/dark and skipped.
CAMERA_MIN_BRIGHTNESS=20

# ── Eye LEDs (Raspberry Pi GPIO, BCM numbering) ──────────────────────────────────
LED_PIN_LEFT=22
LED_PIN_CENTER=23
LED_PIN_RIGHT=27

# ── GC9A01 round face display (optional, Pi only — wiring in config.py) ───────────
DISPLAY_ENABLED=false
DISPLAY_SPI_BUS=0
DISPLAY_SPI_DEVICE=0
DISPLAY_SPI_HZ=40000000
DISPLAY_DC_PIN=25
DISPLAY_RST_PIN=24
DISPLAY_BL_PIN=12
DISPLAY_ROTATION=0

# ── Internal temperature monitoring (Pi only; no-op without a thermal sensor) ─────
TEMP_MONITOR_ENABLED=true
TEMP_WARN_THRESHOLD=80
TEMP_CLEAR_THRESHOLD=72
TEMP_CHECK_INTERVAL=30
TEMP_WARN_COOLDOWN=300

# ── Misc ─────────────────────────────────────────────────────────────────────────
# Where conversation history is persisted (gitignored).
HISTORY_FILE=history.json
# Set true to print per-chunk RMS while recording and save debug WAVs to /tmp.
AUDIO_DEBUG=false
