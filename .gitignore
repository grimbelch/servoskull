# Secrets — never commit
.env
.spotify_cache

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Piper voice model (60MB binary — download separately, see README)
models/*.onnx

# macOS
.DS_Store

# Runtime state — generated at runtime, may contain personal data extracted from
# conversations (names, addresses, etc.). Never commit.
history.json
memory.json
longterm_memory.json
reminders.json
mood.json
quiet.json
*.json.bak

# Per-user configuration written by the setup wizard (keys + personal details).
# owner.example.json IS committed as a template; owner.json is the user's real data.
owner.json
settings.json

# Claude Code local settings
.claude/

# Offline game rulesets the skull references (see skull/search.py, RULES_DIR).
# Third-party copyrighted rules text (e.g. Games Workshop / Necromunda) downloaded
# for personal local reference only — never redistribute / commit to a public repo.
Rules/*
# ...but DO track the (non-copyrighted) tooling and docs that build the library.
!Rules/README.md
!Rules/ingest_pdf.py
