# Secrets — never commit
.env
.spotify_cache

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# macOS
.DS_Store

# Runtime state — generated at runtime, may contain personal data extracted from
# conversations (names, addresses, etc.). Never commit.
history.json
memory.json
longterm_memory.json
reminders.json
mood.json
quiet.json
*.json.bak

# Per-user configuration written by the setup wizard (keys + personal details).
# owner.example.json IS committed as a template; owner.json is the user's real data.
owner.json
settings.json

# Claude Code local settings
.claude/

# Offline game rulesets the skull references (see skull/search.py, RULES_DIR).
# Official Games Workshop rules text (Necromunda, Warhammer 40k) is copyrighted —
# kept local only, never committed to this public repo.
Rules/*
# Tracked: the tooling/docs that build the library, plus the free fan-made
# community rulesets (NetEpic / Epic 2nd ed, NetEA / Epic 3rd ed / "Armageddon"),
# which are openly distributed and safe to publish.
!Rules/README.md
!Rules/ingest_pdf.py
!Rules/clean_necromunda_tables.py
!Rules/netepic/
!Rules/netea/
